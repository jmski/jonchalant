{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "outDir": ".ts-node-out"
  },
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
